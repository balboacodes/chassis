{
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "exports": "./src/index.ts",
  "fmt": {
    "include": ["src/"],
    "indentWidth": 4,
    "singleQuote": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "lint": {
    "include": ["src/"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "check": "deno check",
    "dev": "deno run --watch public/index.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test"
  },
  "test": {
    "include": ["tests/"]
  }
}
