{
  "name": "@balboacodes/chassis",
  "version": "0.1.0",
  "license": "MIT",
  "exports": "./src/framework/main.ts",
  "publish": {
    "include": ["src/framework", "LICENSE", "README.md"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5"
  },
  "tasks": {
    "check": "deno check",
    "dev": "cd src && deno run --allow-read --allow-env --allow-net --watch public/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test"
  },
  "fmt": {
    "include": ["src/"],
    "indentWidth": 4,
    "singleQuote": true
  },
  "lint": {
    "include": ["src/"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "test": {
    "include": ["tests/"]
  },
  "vendor": true
}
