{
    "compilerOptions": {
        // Output & module system
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "node16",
        "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],

        // Directories
        "rootDir": "./",
        "outDir": "dist",

        // Interop
        "esModuleInterop": true,

        // Decorators (for IoC, routing, etc.)
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        // Strictness & safety
        "strict": true,
        "noImplicitAny": true,

        // Builds
        "sourceMap": true,
        "removeComments": true,
        "declaration": true,
        "declarationMap": true,

        // Environment
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "dist", "tests/**/*.ts"]
}
