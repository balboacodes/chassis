{
    "compilerOptions": {
        // Output & module system
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "node16",
        "lib": ["ESNext"],

        // Directories
        "rootDir": "src",
        "outDir": "dist",

        // Interop
        "esModuleInterop": true,

        // Decorators (for IoC, routing, etc.)
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        // Strictness & safety
        "strict": true,
        "noImplicitAny": true,

        // Builds
        "sourceMap": true,
        "removeComments": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "dist/types",

        // Environment
        "skipLibCheck": true,
        "types": ["@types/node"]
    },
    "include": ["src/**/*.ts"]
}
